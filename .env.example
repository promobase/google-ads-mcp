# Google Ads API — copy to .env and fill in values.
# Call order: main.py runs load_dotenv() first, then the SDK reads GOOGLE_ADS_*.
#
# Choose ONE auth path (the Python SDK picks installed-app OAuth if all three
# OAuth vars are set; otherwise service account if JSON key path is set):
#   - Installed app OAuth: common for individual developers / MCC without Workspace SA.
#   - Service account: needs a Google Workspace domain + domain-wide delegation;
#     typically set GOOGLE_ADS_IMPERSONATED_EMAIL to the user to act as.

# Required for env-based config (matches google-ads library validation)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_USE_PROTO_PLUS=true

# --- Option A: OAuth2 installed application (refresh token) ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# --- Option B: Service account (JSON key + delegation) ---
# GOOGLE_ADS_JSON_KEY_FILE_PATH=C:/path/to/service_account.json
# GOOGLE_ADS_IMPERSONATED_EMAIL=user@yourworkspace.com

# Optional: manager / MCC login customer ID (no hyphens)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Optional: load full config from YAML instead of scattering secrets in .env
# (same schema as https://developers.google.com/google-ads/api/docs/client-libs/python/configuration)
# GOOGLE_ADS_CONFIGURATION_FILE_PATH=./env/google-ads.yaml

# Optional: API endpoint / proxy / linked customer (see SDK config keys)
# GOOGLE_ADS_ENDPOINT=
# GOOGLE_ADS_HTTP_PROXY=
# GOOGLE_ADS_LINKED_CUSTOMER_ID=
